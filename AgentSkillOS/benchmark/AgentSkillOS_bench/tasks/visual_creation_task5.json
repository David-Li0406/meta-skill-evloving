{
  "task_id": "visual_creation_task5",
  "task_name": "Digital Art Exhibition Immersive Multimedia Website",
  "description": "Create a promotional website for a digital art exhibition, combining AI-generated artwork, image processing for thumbnails and banners.",
  "skills": [
    "generate-image",
    "media-processing",
    "frontend-design"
  ],
  "prompt": "I am an art director, and I'm organizing a digital art exhibition called \"FutureScape\". I need a promotional website to showcase the exhibition online. Please generate 6 artwork images: cyberpunk.png, biomechanical.png, interstellar.png, deep_sea.png, quantum_garden.png, time_corridor.png. Create smaller preview versions around 400×300: cyberpunk_thumb.png, biomechanical_thumb.png, interstellar_thumb.png, deep_sea_thumb.png, quantum_garden_thumb.png, time_corridor_thumb.png. Combine all 6 artworks into a wide banner image as banner.jpg.\n\nBuild index.html with: a hero section featuring the banner, 6 artwork showcase sections, a thumbnail gallery grid, dark theme with neon accents in cyan/magenta/purple, and responsive design.",
  "outputs": [
    "cyberpunk.png",
    "biomechanical.png",
    "interstellar.png",
    "deep_sea.png",
    "quantum_garden.png",
    "time_corridor.png",
    "cyberpunk_thumb.png",
    "biomechanical_thumb.png",
    "interstellar_thumb.png",
    "deep_sea_thumb.png",
    "quantum_garden_thumb.png",
    "time_corridor_thumb.png",
    "banner.jpg",
    "index.html"
  ],
  "category": "visual_creation",
  "aggregation": {
    "strategy": "weighted_sum"
  },
  "evaluators": [
    {
      "id": "cyberpunk_artwork_exists",
      "type": "objective_usability",
      "op_func": "file_exists",
      "description": "Check that cyberpunk.png artwork exists",
      "weight": 1,
      "op_args": {
        "path": "cyberpunk.png",
        "min_size": 1
      }
    },
