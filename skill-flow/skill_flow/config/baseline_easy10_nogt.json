{
  "system": {},
  "index": {
    "input_corpus_path": "data/skills/",
    "output_index_path": "outputs/indices/bge-base/"
  },
  "models": {
    "retriever": {
      "top_k": 200,
      "model_name": "BAAI/bge-base-en-v1.5",
      "query_prompt": "Represent this sentence for searching relevant passages: ",
      "batch_size": 64,
      "query_gen": {
        "enabled": false,
        "model": "gpt-4o-mini",
        "max_tokens": 200,
        "temperature": 0.0,
        "num_queries": 1,
        "aggregation": "max"
      }
    },
    "reranker": {
      "enabled": true,
      "input_top_k": 50,
      "model_name": "cross-encoder/ms-marco-MiniLM-L-6-v2",
      "batch_size": 64,
      "max_content_chars": 512,
      "query_gen": {
        "enabled": false,
        "model": "gpt-4o-mini",
        "max_tokens": 200,
        "temperature": 0.0,
        "num_queries": 1,
        "aggregation": "max"
      }
    },
    "deep_reranker": {
      "enabled": false,
      "input_top_k": 20,
      "model_name": "cross-encoder/ms-marco-MiniLM-L-6-v2",
      "batch_size": 64,
      "max_content_chars": 2048,
      "query_gen": {
        "enabled": false,
        "model": "gpt-4o-mini",
        "max_tokens": 200,
        "temperature": 0.0,
        "num_queries": 1,
        "aggregation": "max"
      }
    },
    "selector": {
      "enabled": true,
      "input_top_k": 5,
      "model": "gpt-4o-mini",
      "system_instruction": "skill_flow/selector/instructions/system_v1.0.j2",
      "user_instruction": "skill_flow/selector/instructions/user_v0.1.j2",
      "max_tokens": 1024,
      "temperature": 0.0,
      "cache_path": "outputs/pipeline/baseline_easy10_nogt/selector_cache.json"
    }
  },
  "pipeline": {
    "tasks_dir": "integration/skillsbench/tasks-easy10-no-skills",
    "output_dir": "outputs/pipeline/baseline_easy10_nogt/",
    "include_tasks": [
      "powerlifting-coef-calc",
      "offer-letter-generator",
      "dialogue-parser",
      "court-form-filling",
      "fix-build-agentops",
      "lake-warming-attribution",
      "threejs-to-obj",
      "threejs-structure-parser",
      "travel-planning",
      "crystallographic-wyckoff-position-analysis"
    ]
  }
}