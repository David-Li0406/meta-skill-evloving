{
  "source_index_dir": "outputs/indices/bge-base-36k/",
  "source_corpus_dir": "data/skills/",
  "eps": 0.1,
  "engine": "autoskill",
  "output_corpus_dir": "data/skills-refined-autoskill-36k/",
  "report_dir": "outputs/refiner-autoskill-36k/",
  "autoskill": {
    "enabled": true,
    "model": "gpt-4o-mini",
    "max_tokens": 64,
    "temperature": 0.0,
    "top_k": 8,
    "similarity_threshold": 0.88,
    "max_workers": 32,
    "instruction_path": "skill_flow/refiner/instructions/autoskill_merge_judge_v1.j2",
    "cache_path": "outputs/refiner-autoskill-36k/autoskill_judge_cache.json"
  },
  "merger": {
    "enabled": true,
    "model": "gpt-4o-mini",
    "max_tokens": 3500,
    "temperature": 0.0,
    "max_group_size": 5,
    "max_workers": 32,
    "skip_cluster_size_above": 5,
    "instruction_path": "skill_flow/refiner/instructions/merge_v1.j2",
    "cache_path": "outputs/refiner-autoskill-36k/merge_cache.json"
  },
  "quality_filter": {
    "enabled": true,
    "model": "gpt-4o-mini",
    "max_tokens": 512,
    "temperature": 0.0,
    "max_workers": 32,
    "instruction_path": "skill_flow/refiner/instructions/filter_v1.j2",
    "cache_path": "outputs/refiner-autoskill-36k/filter_cache.json"
  }
}