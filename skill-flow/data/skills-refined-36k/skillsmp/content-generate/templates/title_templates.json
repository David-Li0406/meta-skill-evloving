{
  "title_templates": {
    "wechat_article": {
      "patterns": [
        "深度解析：{topic}",
        "全面解读：{topic}",
        "{topic}：从入门到精通",
        "揭秘{topic}，原来如此",
        "关于{topic}，你需要知道的一切"
      ],
      "keywords": ["深度", "全面", "解析", "解读", "揭秘", "入门", "精通"]
    },
    "xiaohongshu": {
      "patterns": [
        "姐妹们！{topic}真的绝了🔥",
        "必看！{topic}的{number}个方法",
        "绝绝子！{topic}这样也太好了✨",
        "宝藏{topic}分享！亲测有效💯",
        "姐妹们听我说，{topic}真的可以"
      ],
      "keywords": ["姐妹们", "绝了", "必看", "宝藏", "亲测", "分享", "安利"],
      "emojis": ["🔥", "✨", "💯", "💪", "❤️", "🎉"]
    },
    "douyin": {
      "patterns": [
        "没想到！{topic}",
        "{topic}竟然这么简单！",
        "震惊！{topic}",
        "这个{topic}真的绝了",
        "快看！{topic}的秘密"
      ],
      "keywords": ["没想到", "震惊", "绝了", "快看", "竟然", "秘密"],
      "emojis": ["😱", "🔥", "✨", "💯"]
    },
    "zhihu": {
      "patterns": [
        "如何评价{topic}？",
        "如何看待{topic}？",
        "{topic}：深度分析与思考",
        "关于{topic}的全面观察",
        "{topic}背后的逻辑是什么？"
      ],
      "keywords": ["如何评价", "如何看待", "深度分析", "全面观察", "逻辑", "思考"]
    },
    "ecommerce": {
      "patterns": [
        "{topic}：限时特惠",
        "超值{topic}，今日特价",
        "必买！{topic}推荐",
        "{topic}，性价比首选",
        "爆款{topic}，热销中"
      ],
      "keywords": ["限时", "特惠", "特价", "必买", "推荐", "性价比", "爆款", "热销"]
    }
  },
  "title_styles": {
    "professional": {
      "vocabulary": ["专业", "深度", "全面", "解析", "研究"],
      "patterns": ["{topic}研究", "{topic}分析", "关于{topic}的探讨"]
    },
    "casual": {
      "vocabulary": ["轻松", "有趣", "好玩", "简单"],
      "patterns": ["轻松搞定{topic}", "{topic}其实很简单", "有趣{topic}分享"]
    },
    "emotional": {
      "vocabulary": ["温暖", "感人", "真实", "故事"],
      "patterns": ["温暖的{topic}", "真实的{topic}故事", "让人感动的{topic}"]
    },
    "curiosity": {
      "vocabulary": ["秘密", "真相", "没想到", "发现"],
      "patterns": ["{topic}的秘密", "没想到{topic}", "发现{topic}的真相"]
    }
  }
}
