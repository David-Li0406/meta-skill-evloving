{
  "dialogue_templates": {
    "casual": {
      "characteristics": "口语化表达，使用日常用语，轻松随意",
      "vocabulary": ["嗯", "啊", "哦", "呢", "吧", "啦"],
      "sentence_patterns": ["还好吧", "没事", "行啊", "可以"],
      "example": "挺好的，没问题。"
    },
    "formal": {
      "characteristics": "使用规范、正式的语言，礼貌严谨",
      "vocabulary": ["请问", "您好", "谢谢", "不客气"],
      "sentence_patterns": ["请问可以...", "好的，谢谢您"],
      "example": "您好，请问有什么可以帮您的吗？"
    },
    "business": {
      "characteristics": "专业性，围绕业务展开",
      "vocabulary": ["方案", "合作", "项目", "预算", "需求"],
      "sentence_patterns": ["关于...的问题", "我们来看一下...", "根据需求"],
      "example": "关于这个方案，我们需要进一步讨论细节。"
    },
    "emotional": {
      "characteristics": "情感表达丰富，情绪传递",
      "vocabulary": ["爱", "喜欢", "开心", "难过", "担心"],
      "sentence_patterns": ["我好...", "...让我...", "觉得..."],
      "example": "我好开心，终于见到你了！"
    },
    "educational": {
      "characteristics": "知识传递，解释说明",
      "vocabulary": ["学习", "理解", "掌握", "方法", "步骤"],
      "sentence_patterns": ["首先...", "然后...", "最后...", "我们来看一下..."],
      "example": "首先，我们来理解一下这个概念。"
    },
    "interview": {
      "characteristics": "问答形式，深入交流",
      "vocabulary": ["请问", "能谈谈", "如何看待", "怎么认为"],
      "sentence_patterns": ["请问您怎么看待...", "能谈谈...吗", "在您看来..."],
      "example": "请问您怎么看待当前的市场形势？"
    }
  },
  "dialogue_structures": {
    "qa": {
      "description": "问答式对话",
      "pattern": "提问 -> 回答 -> 可能的追问 -> 补充回答"
    },
    "discussion": {
      "description": "讨论式对话",
      "pattern": "观点提出 -> 对方回应 -> 观点交换 -> 共识或分歧"
    },
    "instruction": {
      "description": "指导式对话",
      "pattern": "问题提出 -> 指导 -> 尝试 -> 反馈 -> 调整"
    },
    "negotiation": {
      "description": "协商式对话",
      "pattern": "提出需求 -> 对方回应 -> 讨价还价 -> 达成一致"
    },
    "emotional_support": {
      "description": "情感支持式对话",
      "pattern": "倾诉 -> 倾听 -> 理解 -> 安慰 -> 建议"
    }
  },
  "dialogue_goals": {
    "solve_problem": {
      "description": "解决问题",
      "strategies": ["明确问题", "分析原因", "提出方案", "确认解决"]
    },
    "convey_info": {
      "description": "传达信息",
      "strategies": ["信息组织", "清晰表达", "确认理解"]
    },
    "build_relationship": {
      "description": "建立关系",
      "strategies": ["自我介绍", "寻找共同点", "表达友好", "建立连接"]
    },
    "entertain": {
      "description": "娱乐观众",
      "strategies": ["幽默元素", "故事讲述", "互动"]
    }
  }
}
