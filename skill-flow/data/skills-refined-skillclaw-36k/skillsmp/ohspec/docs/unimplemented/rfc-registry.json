  "status_definitions": {
    "draft": {
      "label": "草稿",
      "description": "RFC 已创建，等待分析",
      "color": "#808080",
      "transitions_to": [
        "analyzing",
        "rejected"
      ]
    },
    "analyzing": {
      "label": "分析中",
      "description": "正在进行需求分析和代码扫描",
      "color": "#FFA500",
      "transitions_to": [
        "designing",
        "draft",
        "rejected"
      ]
    },
    "designing": {
      "label": "设计中",
      "description": "正在进行架构设计和接口定义",
      "color": "#4169E1",
      "transitions_to": [
        "prechecking",
        "analyzing",
        "rejected"
      ]
    },
    "prechecking": {
      "label": "预检中",
      "description": "进行结构完整性和覆盖度检查",
      "color": "#9370DB",
      "transitions_to": [
        "auditing",
        "designing",
        "rejected"
      ]
    },
    "auditing": {
      "label": "审核中",
      "description": "进行质量审查和合规性检查",
      "color": "#FF6347",
      "transitions_to": [
        "approved",
        "rejected",
        "designing"
      ]
    },
    "approved": {
      "label": "已批准",
      "description": "RFC 已通过审核，可进入实现阶段",
      "color": "#228B22",
      "transitions_to": [
        "archived"
      ]
    },
    "rejected": {
      "label": "已拒绝",
      "description": "RFC 未通过审核，需要重新设计或放弃",
      "color": "#DC143C",
      "transitions_to": [
        "draft",
        "archived"
      ]
    },
    "archived": {
      "label": "已归档",
      "description": "RFC 已完成或已放弃，归档保存",
      "color": "#A9A9A9",
      "transitions_to": []
    }
  },
