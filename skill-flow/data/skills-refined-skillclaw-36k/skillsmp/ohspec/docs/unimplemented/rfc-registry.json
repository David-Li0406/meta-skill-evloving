    }
  },
  "queries": {
    "predefined": [
      {
        "id": "active",
        "name": "活跃 RFC",
        "description": "所有进行中的 RFC",
        "filter": {
          "status": [
            "analyzing",
            "designing",
            "prechecking",
            "auditing"
          ]
        }
      },
      {
        "id": "pending-review",
        "name": "待审核",
        "description": "等待审核的 RFC",
        "filter": {
          "status": [
            "auditing"
          ]
        }
      },
      {
        "id": "high-priority",
        "name": "高优先级",
        "description": "优先级为高或紧急的 RFC",
        "filter": {
          "tags.priority": [
            "critical",
            "high"
          ]
        }
      },
      {
        "id": "blocked",
        "name": "被阻塞",
        "description": "被其他 RFC 阻塞的 RFC",
        "filter": {
          "tags.dependency": [
            "blocked-by"
          ]
        }
      },
      {
        "id": "breaking-changes",
        "name": "破坏性变更",
        "description": "包含破坏性变更的 RFC",
        "filter": {
          "tags.risk": [
            "breaking-change"
          ]
        }
      },
      {
        "id": "approved",
        "name": "已批准",
        "description": "已批准的 RFC",
        "filter": {
          "status": [
            "approved"
          ]
        }
      }
    ]
  },
  "export": {
    "formats": [
      "json",
      "csv",
      "markdown",
      "html"
    ],
    "reports": [
      {
        "id": "status-report",
        "name": "状态报告",
        "description": "RFC 执行状态总结",
        "fields": [
          "id",
          "title",
          "status",
          "priority",
          "created_at",
          "updated_at",
          "owner"
        ]
      },
      {
        "id": "timeline-report",
        "name": "时间线报告",
        "description": "RFC 创建和完成时间线",
        "fields": [
          "id",
          "title",
          "created_at",
          "completed_at",
          "duration_days"
        ]
      },
      {
        "id": "dependency-report",
        "name": "依赖关系报告",
        "description": "RFC 间的依赖关系",
        "fields": [
          "id",
          "title",
          "related_rfcs",
          "blocking_rfcs",
          "blocked_by_rfcs"
        ]
      },
      {
        "id": "risk-report",
        "name": "风险评估报告",
        "description": "RFC 风险评估汇总",
        "fields": [
          "id",
          "title",
          "risk_level",
          "impact_scope",
          "mitigation_plan"
        ]
      }
    ]
  },
  "maintenance": {
    "archival": {
      "auto_archive_after_days": 90,
      "archive_conditions": [
        "status == 'approved' AND completed_at < 90 days ago",
        "status == 'rejected' AND updated_at < 90 days ago"
      ]
    },
    "cleanup": {
      "remove_draft_after_days": 180,
      "remove_conditions": [
        "status == 'draft' AND created_at < 180 days ago AND no_activity"
      ]
    },
    "backup": {
      "frequency": "daily",
      "retention_days": 30
    }
  }
}
