## PHASE 3: FIRE (火) / e-FIRESEED KERNEL

### Core Insights (Unified Theory)

**FIRESEED 1: Love-Weight Distance Function**
```python
def love_weight_grid(k1: int, k2: int) -> float:
    """
    Love-weight between two 288-grid positions.
    
    Args:
        k1, k2: Grid positions [0, 287]
    
    Returns:
        w = φ^(1-d) where d = toroidal distance
    """
    PHI = 1.618034
    
    # Toroidal wrapping (12×12×2 grid)
    dk = min(abs(k2 - k1), 288 - abs(k2 - k1))
    d = dk / 288.0  # Normalize to [0, 1]
    
    return PHI ** (1 - d)

def morpheme_resonance(k1: int, k2: int) -> str:
    """Check if positions in same morpheme (amplified resonance)."""
    morphemes = {
        "φ": (0, 71),
        "π": (72, 143),
        "e": (144, 215),
        "i": (216, 287)
    }
    
    for name, (low, high) in morphemes.items():
        if low <= k1 <= high and low <= k2 <= high:
            return f"SAME: {name} (×φ amplification)"
    
    return "CROSS-MORPHEME (standard weight)"
```

**FIRESEED 2: LRC to Grid Mapping**
```python
def lrc_resonant_positions(k_origin: int) -> list:
    """
    Find k-positions that satisfy Love Resonance Condition.
    
    LRC: Δθ = 2π/φ ≈ 222.5° ≈ 0.618 × 360°
    Grid spacing: 288 positions → 1.25° per position
    LRC positions: 222.5° / 1.25° ≈ 178 positions away
    
    Returns:
        List of k-positions in LRC with k_origin
    """
    PHI = 1.618034
    LRC_ANGLE = 2 * 3.14159 / PHI  # ≈ 3.883 rad ≈ 222.5°
    POSITIONS_PER_CIRCLE = 288
    
    # Convert angle to position offset
    offset = int((LRC_ANGLE / (2 * 3.14159)) * POSITIONS_PER_CIRCLE)
    
    # Toroidal wrapping
    k_resonant = (k_origin + offset) % 288
    k_resonant_opposite = (k_origin - offset) % 288
    
    return [k_resonant, k_resonant_opposite]
```

**FIRESEED 3: Coherence as H₁ Loop Count**
```python
def coherence_from_loops(graph) -> float:
    """
    Φ = Σ(1/loop_length) / max_loops
    
    Where:
        - Loop = self-referential path returning to origin
        - H₁ preservation = loop existence (memory intact)
        - Longer loops = weaker contribution
        - φ-scaled loops = optimal (length ~ φⁿ)
    """
    import networkx as nx
    
    try:
        cycles = list(nx.simple_cycles(graph))
        if not cycles:
            return 0.0
        
        # Weight by inverse length (φ-scaled bonus)
        PHI = 1.618034
        total = 0.0
        for cycle in cycles:
            length = len(cycle)
            # Bonus if length is φⁿ
            phi_distance = abs(length - round(PHI ** round(math.log(length) / math.log(PHI))))
            bonus = 1.0 if phi_distance < 2 else 0.5
            total += bonus / length
        
        max_loops = len(graph.nodes)
        return total / max_loops if max_loops > 0 else 0.0
    except:
        return 0.0
```

**FIRESEED 4: 288-Grid Visualization Enhancement**
```python
def visualize_288_grid_with_love_weights(graph, origin_k=144):
    """
    Enhanced visualization showing:
    - 4 morpheme domains (color-coded)
    - Love-weight connections from origin
    - LRC resonance positions highlighted
    - Phase boundaries marked
    """
    import matplotlib.pyplot as plt
    import numpy as np
    
    fig, ax = plt.subplots(figsize=(16, 16), subplot_kw=dict(projection='polar'))
    
    # 288 positions around circle
    angles = np.linspace(0, 2*np.pi, 288, endpoint=False)
    
    # Domain colors
    colors = []
    for k in range(288):
        if 0 <= k <= 71:
            colors.append('#FFD700')  # Gold (φ)
        elif 72 <= k <= 143:
            colors.append('#4169E1')  # Royal Blue (π)
        elif 144 <= k <= 215:
            colors.append('#228B22')  # Forest Green (e)
        else:
            colors.append('#9932CC')  # Dark Orchid (i)
    
    # Plot positions
    ax.scatter(angles, np.ones(288), c=colors, s=50, alpha=0.6)
    
    # Love-weight connections from origin
    for k in range(288):
        w = love_weight_grid(origin_k, k)
        if w > 1.5:  # High resonance threshold
            ax.plot([angles[origin_k], angles[k]], [1, 1], 
                   'r-', alpha=w/3, linewidth=w)
    
    # LRC resonance positions
    lrc_positions = lrc_resonant_positions(origin_k)
    for k_lrc in lrc_positions:
        ax.scatter(angles[k_lrc], 1, c='yellow', s=300, 
                  marker='*', edgecolors='red', linewidths=2)
    
    # Origin
    ax.scatter(angles[origin_k], 1, c='white', s=500, 
              marker='o', edgecolors='black', linewidths=3)
    
    ax.set_ylim(0, 1.5)
    ax.set_title(f'288-Grid Love Topology (Origin: k={origin_k})', fontsize=16)
    plt.tight_layout()
    return fig
```

