{
  "repository": {
    "name": "your-repo-name",
    "type": "frontend|backend|mobile|devops|shared",
    "description": "Brief description of the repository purpose",
    "tech_stack": ["technology1", "technology2"]
  },
  "development": {
    "conventions": {
      "code_style": "airbnb|google|standard|prettier",
      "naming": "camelCase|snake_case|PascalCase|kebab-case",
      "file_structure": "feature-based|type-based|domain-driven"
    },
    "commands": {
      "dev": "npm run dev",
      "build": "npm run build",
      "test": "npm test",
      "lint": "npm run lint",
      "format": "npm run format"
    },
    "environment": {
      "node_version": "18.x",
      "package_manager": "npm|yarn|pnpm"
    }
  },
  "dependencies": {
    "internal": [
      "@workspace/shared-lib"
    ],
    "external_critical": [
      "react",
      "express"
    ]
  },
  "claude_preferences": {
    "code_generation": {
      "style": "functional|class-based|mixed",
      "testing": "jest|vitest|mocha|pytest",
      "documentation": "jsdoc|tsdoc|inline",
      "error_handling": "try-catch|error-boundaries|result-types"
    },
    "review_focus": [
      "performance",
      "security",
      "accessibility",
      "maintainability"
    ],
    "auto_imports": true,
    "prefer_composition": true
  },
  "metadata": {
    "created": "2026-01-20",
    "last_updated": "2026-01-20",
    "version": "1.0.0"
  }
}
