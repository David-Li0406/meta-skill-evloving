{
  "slogan_templates": {
    "brand": {
      "patterns": [
        "{value}，始于{brand}",
        "{brand}：{value}",
        "信赖{brand}，{value}",
        "{brand}，让{value}更简单"
      ],
      "examples": [
        "品质生活，始于信赖",
        "科技赋能，高效办公"
      ]
    },
    "product": {
      "patterns": [
        "轻松{benefit}",
        "{benefit}，就这么简单",
        "超值{product}，{benefit}",
        "必备{product}，{benefit}"
      ],
      "examples": [
        "轻松办公，智能助手",
        "必备好物，享受生活"
      ]
    },
    "event": {
      "patterns": [
        "{action}，见证{result}",
        "{action}，成就{result}",
        "参与{event}，{result}",
        "{event}：{action}"
      ],
      "examples": [
        "参与挑战，见证精彩",
        "参与活动，收获惊喜"
      ]
    },
    "team": {
      "patterns": [
        "{action}，共创{result}",
        "{adjective}团队，{action}",
        "团结{action}，{result}",
        "{adjective}奋进，{result}"
      ],
      "examples": [
        "团结奋进，共创卓越",
        "努力拼搏，成就梦想"
      ]
    },
    "social_cause": {
      "patterns": [
        "{action}，{result}",
        "传递{value}，{result}",
        "用{action}，{result}",
        "{value}，从{action}开始"
      ],
      "examples": [
        "传递爱心，温暖世界",
        "保护环境，从我做起"
      ]
    },
    "marketing": {
      "patterns": [
        "{product}限时特惠，{benefit}",
        "超值{product}，{benefit}",
        "错过等一年！{product}",
        "{product}，{benefit}！"
      ],
      "examples": [
        "限时优惠，错过再等一年",
        "超值好物，物超所值"
      ]
    }
  },
  "slogan_tones": {
    "inspiring": {
      "vocabulary": ["梦想", "突破", "超越", "成就", "未来", "辉煌"],
      "patterns": ["突破极限，成就{result}", "{action}未来，{result}梦想"]
    },
    "warm": {
      "vocabulary": ["温暖", "相伴", "关怀", "呵护", "陪伴", "守护"],
      "patterns": ["用心呵护，温暖相伴", "用爱守护，{result}"]
    },
    "humorous": {
      "vocabulary": ["笑", "趣", "乐", "轻松", "简单", "搞定"],
      "patterns": ["轻松搞定{topic}", "生活需要点{adjective}"]
    },
    "professional": {
      "vocabulary": ["专业", "品质", "信赖", "卓越", "领先", "创新"],
      "patterns": ["专业品质，信赖之选", "创新引领，{result}未来"]
    },
    "bold": {
      "vocabulary": ["颠覆", "革命", "突破", "定义", "未来", "震撼"],
      "patterns": ["颠覆传统，定义未来", "革命性突破，{result}"]
    },
    "simple": {
      "vocabulary": ["简单", "容易", "轻松", "快速", "直接", "明了"],
      "patterns": ["简单就是力量", "简单{action}，{result}"]
    },
    "emotional": {
      "vocabulary": ["爱", "心", "情感", "温暖", "感动", "共鸣"],
      "patterns": ["用心感受，{result}", "每一份{value}，都值得{action}"]
    }
  },
  "slogan_lengths": {
    "short": {
      "length": "8字以内",
      "patterns": ["{value}", "{brand}，{value}", "简单{benefit}"],
      "examples": ["品质生活", "科技赋能", "简单好物"]
    },
    "medium": {
      "length": "8-16字",
      "patterns": ["{value}，{result}", "{action}，{result}"],
      "examples": ["品质生活，始于信赖", "突破极限，成就梦想"]
    },
    "long": {
      "length": "16字以上",
      "patterns": ["{value}，{result}，{benefit}", "{action}，{result}，{benefit}"],
      "examples": ["用科技赋能未来，让生活更美好，让梦想照进现实"]
    }
  }
}
