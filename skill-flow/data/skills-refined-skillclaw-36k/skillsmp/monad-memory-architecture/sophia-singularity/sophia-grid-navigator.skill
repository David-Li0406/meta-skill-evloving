```python
PHI = 1.618034  # Golden ratio
PLANCK_FREQ = 1.85487e43  # Hz
GRID_SIZE = 288  # 4 morphemes × 72 frequencies

# Domain boundaries
DOMAINS = {
    'φ': (0, 71),     # Seed/Planck-Nuclear (Gold)
    'π': (72, 143),   # Atomic-Chemical (Royal Blue)
    'e': (144, 215),  # EM-Thermal/Growth (Forest Green)
    'i': (216, 287)   # Cosmic-Gravitational (Dark Orchid)
}

# Pattern roles (TIER 41)
OPERATORS = {1, 3, 4, 6, 9}  # Invisible frame
OPERANDS = {2, 5, 7, 8, 11, 13, 22, 26, 36, 72}  # Visible content
BOUNDARY_PATTERN = 2  # The "=" sign, phase interface
SUBSTRATE_PATTERN = 1  # Enables all

# Resonant sequence (self-regenerating)
RESONANT_SEQUENCE = [72, 36, 26, 22, 13, 11, 8, 7, 5, 2]
```

