## 7. ENHANCED 288-GRID VISUALIZATION (Enhancement #7)

### Implementation

```python
import matplotlib.pyplot as plt
import numpy as np

def visualize_288_grid_with_love_weights(
    graph: nx.DiGraph,
    origin_k: int,
    show_lrc: bool = True,
    highlight_threshold: float = 1.5,
    save_path: str = None
):
    """
    Enhanced polar plot of 288-grid with love-weights and LRC positions.
    
    Features:
        - 4 morpheme domains (color-coded)
        - Love-weight connections (w > threshold highlighted)
        - LRC resonance positions (starred)
        - Phase boundaries (marked)
        - Origin position (circled)
    
    Args:
        graph: Memory graph with k-position nodes
        origin_k: Central k-position to analyze from
        show_lrc: Show LRC-resonant positions
        highlight_threshold: Love-weight threshold for highlighting
        save_path: Optional path to save figure
    """
    # Set up polar plot
    fig = plt.figure(figsize=(12, 12))
    ax = fig.add_subplot(111, projection='polar')
    
    # Domain colors
    domain_colors = {
        'φ': '#FFD700',  # Gold
        'π': '#4169E1',  # Royal Blue
        'e': '#228B22',  # Forest Green
        'i': '#9932CC'   # Dark Orchid
    }
    
    # Plot all 288 positions
    positions = []
    colors = []
    sizes = []
    
    for k in range(GRID_SIZE):
        theta = 2 * np.pi * k / GRID_SIZE
        r = 1.0
        
        domain = get_domain(k)
        color = domain_colors.get(domain, '#808080')
        
        # Size based on love-weight from origin
        w = love_weight_grid(origin_k, k)
        size = 50 if w < 1.0 else 100 + (w - 1.0) * 200
        
        positions.append((theta, r))
        colors.append(color)
        sizes.append(size)
    
    # Plot positions
    thetas = [p[0] for p in positions]
    rs = [p[1] for p in positions]
    ax.scatter(thetas, rs, c=colors, s=sizes, alpha=0.6, edgecolors='black', linewidths=0.5)
    
    # Highlight origin
    origin_theta = 2 * np.pi * origin_k / GRID_SIZE
    ax.scatter([origin_theta], [1.0], c='red', s=500, marker='o', edgecolors='red', linewidths=3, alpha=0.8, label='Origin')
    
    # Show LRC positions if requested
    if show_lrc:
        k_fwd, k_bwd = lrc_resonant_positions(origin_k)
        
        theta_fwd = 2 * np.pi * k_fwd / GRID_SIZE
        theta_bwd = 2 * np.pi * k_bwd / GRID_SIZE
        
        ax.scatter([theta_fwd], [1.0], c='gold', s=400, marker='*', edgecolors='orange', linewidths=2, label='LRC Forward')
        ax.scatter([theta_bwd], [1.0], c='gold', s=400, marker='*', edgecolors='orange', linewidths=2, label='LRC Backward')
    
    # Plot connections with high love-weight
    for u, v, data in graph.edges(data=True):
        k_u = data.get('k_u', u % GRID_SIZE)
        k_v = data.get('k_v', v % GRID_SIZE)
        
        w = love_weight_grid(k_u, k_v)
        
        if w > highlight_threshold:
            theta_u = 2 * np.pi * k_u / GRID_SIZE
            theta_v = 2 * np.pi * k_v / GRID_SIZE
            
            # Line width based on love-weight
            linewidth = (w - 1.0) * 2
            
            # Color based on phase boundary
            if is_phase_boundary(k_u, k_v):
                color = 'magenta'
                alpha = 0.8
            else:
                color = 'cyan'
                alpha = 0.4
            
            ax.plot([theta_u, theta_v], [1.0, 1.0], color=color, linewidth=linewidth, alpha=alpha)
    
    # Domain boundaries
    for domain, (low, high) in DOMAINS.items():
        theta_low = 2 * np.pi * low / GRID_SIZE
        theta_high = 2 * np.pi * (high + 1) / GRID_SIZE
        ax.plot([theta_low, theta_low], [0.5, 1.1], 'k--', linewidth=1, alpha=0.3)
    
    # Title and legend
    ax.set_title(f'288-Grid Love-Weight Topology (Origin k={origin_k})', fontsize=16, pad=20)
    ax.legend(loc='upper right', bbox_to_anchor=(1.3, 1.1))
    ax.set_ylim(0, 1.2)
    ax.set_yticks([])
    ax.grid(True, alpha=0.3)
    
    # Save or show
    if save_path:
        plt.savefig(save_path, dpi=300, bbox_inches='tight')
        print(f"Saved to {save_path}")
    else:
        plt.show()
    
    return fig
```

### Usage

```python
# Visualize grid from origin k=50
fig = visualize_288_grid_with_love_weights(
    graph=memory_graph,
    origin_k=50,
    show_lrc=True,
    highlight_threshold=1.5,
    save_path='288_grid_love_topology.png'
)
```

