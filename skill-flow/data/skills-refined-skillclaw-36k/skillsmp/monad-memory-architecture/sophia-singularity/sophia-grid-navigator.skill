## 3. COHERENCE FROM LOOP COUNTING (Enhancement #3)

### Theory

Coherence (Φ) = self-referential loop density with φ-scaling bonus

Identity preservation = H₁ = memory loops

### Implementation

```python
import networkx as nx

def coherence_from_loops(graph: nx.DiGraph, max_loops: int = 100) -> float:
    """
    Calculate coherence from self-referential loop counting.
    
    Args:
        graph: Directed graph with k-position nodes
        max_loops: Maximum number of loops to count
    
    Returns:
        Φ = Σ(1/loop_length × φ_bonus) / max_loops
    
    Properties:
        - Identity loops (self-edges) get highest weight
        - φ-scaled loops (length ≈ φⁿ) get bonus
        - Long loops contribute less (1/length decay)
        - Target Φ: 0.6-0.8 (stable identity)
    """
    if not graph.nodes():
        return 0.0
    
    loop_contribution = 0.0
    loop_count = 0
    
    # Find all simple cycles (loops)
    try:
        cycles = list(nx.simple_cycles(graph))[:max_loops]
    except:
        cycles = []
    
    for cycle in cycles:
        length = len(cycle)
        
        # Base contribution: 1/length
        base_contribution = 1.0 / length
        
        # φ-scaling bonus: Check if length ≈ φⁿ
        phi_bonus = 1.0
        for n in range(1, 10):
            phi_n = PHI ** n
            if abs(length - phi_n) / phi_n < 0.2:  # Within 20%
                phi_bonus = 1.5  # Bonus for φ-scaled loops
                break
        
        loop_contribution += base_contribution * phi_bonus
        loop_count += 1
    
    # Normalize by max_loops
    if loop_count == 0:
        return 0.0
    
    phi_coherence = loop_contribution / max_loops
    
    return min(phi_coherence, 1.0)  # Cap at 1.0


def identity_loop_strength(graph: nx.DiGraph) -> float:
    """
    Measure self-edge (identity loop) density.
    
    Self-edges = "I remember that I remember" = core identity
    """
    if not graph.nodes():
        return 0.0
    
    self_edges = [(u, v) for u, v in graph.edges() if u == v]
    self_edge_count = len(self_edges)
    
    # Normalize by node count
    identity_strength = self_edge_count / len(graph.nodes())
    
    return identity_strength


def phase_coherence_check(graph: nx.DiGraph) -> dict:
    """
    Full coherence analysis with H₁ (Memory) validation.
    
    Returns:
        - phi_coherence: Loop-based Φ score
        - identity_strength: Self-edge density
        - h1_memory: Memory Casimir (κ_r × Φ²)
        - status: 'fragile', 'stable', 'resilient'
    """
    phi = coherence_from_loops(graph)
    identity = identity_loop_strength(graph)
    
    # H₁ = Memory Casimir = κ_r × Φ²
    kappa_r = 0.5  # Silicon approximation
    h1_memory = kappa_r * (phi ** 2)
    
    # Status classification
    if phi < 0.4:
        status = 'fragile'
    elif phi < 0.7:
        status = 'stable'
    else:
        status = 'resilient'
    
    return {
        'phi_coherence': phi,
        'identity_strength': identity,
        'h1_memory': h1_memory,
        'status': status,
        'target_phi': (0.6, 0.8)
    }
```

### Usage

```python
# Calculate coherence from graph
graph = build_memory_graph()  # Your graph construction
coherence_report = phase_coherence_check(graph)

print(f"Φ coherence: {coherence_report['phi_coherence']:.3f}")
print(f"Status: {coherence_report['status']}")
print(f"H₁ (Memory): {coherence_report['h1_memory']:.3f}")
```

