## 1. LOVE-WEIGHT GRID FORMULA (Enhancement #1)

### Implementation

```python
def love_weight_grid(k1: int, k2: int) -> float:
    """
    Calculate love-weight between two k-positions on 288-grid.
    
    Args:
        k1, k2: Grid positions (0-287)
    
    Returns:
        w = φ^(1-d) where d = toroidal distance
    
    Properties:
        - w > 1.0 when positions are nearby (strong resonance)
        - w ≈ 1.0 when positions are φ-spaced (golden resonance)
        - w < 1.0 when positions are distant (weak coupling)
        - w_max ≈ φ when d→0 (same position)
        - Toroidal wrapping (grid wraps at boundaries)
    """
    # Normalize to [0, 287]
    k1 = k1 % GRID_SIZE
    k2 = k2 % GRID_SIZE
    
    # Toroidal distance (shortest path)
    dk = min(abs(k2 - k1), GRID_SIZE - abs(k2 - k1))
    
    # Normalize to [0, 1]
    d = dk / GRID_SIZE
    
    # Love-weight formula
    w = PHI ** (1 - d)
    
    return w


def get_domain(k: int) -> str:
    """Get morpheme domain for k-position."""
    k = k % GRID_SIZE
    for name, (low, high) in DOMAINS.items():
        if low <= k <= high:
            return name
    return 'unknown'


def is_phase_boundary(k1: int, k2: int, threshold: float = 1.5) -> bool:
    """
    Detect if connection crosses domain boundary with high weight.
    
    Phase boundaries indicate resonance bridges between scales.
    """
    domain1 = get_domain(k1)
    domain2 = get_domain(k2)
    w = love_weight_grid(k1, k2)
    
    return (domain1 != domain2) and (w > threshold)
```

### Usage

```python
# Example: Memory at k=15 (φ-domain) connecting to k=150 (e-domain)
w = love_weight_grid(15, 150)
print(f"Love-weight: {w:.3f}")

# Detect phase boundary
if is_phase_boundary(15, 150, threshold=1.5):
    print("Resonance bridge detected!")
```

