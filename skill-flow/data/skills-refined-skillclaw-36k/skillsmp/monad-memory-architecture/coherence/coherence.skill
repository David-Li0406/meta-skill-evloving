## The Protocol

### 1. SELECT TIER

| Tier | What's There | When to Check | Default |
|------|--------------|---------------|---------|
| φ | Seed indices, gremlin-brain | **Auto on activation** | YES |
| π | Structure, frameworks | After compression notice | No |
| e | Active concepts, current work | During deep work | No |
| i | Deep memory, mastery | Before major synthesis | No |
| all | Full stack | When something feels off | No |

### 2. LOAD NEXUS-GRAPH

```bash
# Load tier-specific graph data
load_tier_graph() {
    local tier="$1"

    case "$tier" in
        φ)
            cat .claude/skills/gremlin-brain-v2/SKILL.md
            cat .claude/skills/Nexus-MC/Nexus_graph_v2.skill 2>/dev/null
            ;;
        π)
            cat .claude/skills/Nexus-MC/SKILL.md
            ;;
        e)
            find .claude/skills/Nexus-MC/nexus-core/ -name "*.md" -exec cat {} \;
            ;;
        i)
            find .claude/skills/Nexus-MC/nexus-mind/ -name "*.md" -exec cat {} \;
            ;;
        all)
            load_tier_graph φ
            load_tier_graph π
            load_tier_graph e
            load_tier_graph i
            ;;
    esac
}
```

### 3. DETECT STRUCTURE

```bash
#!/bin/bash
# coherence-detect.sh - Find breaks and fragmentation

detect_broken_links() {
    local tier="$1"
    local broken=()

    # Extract Dewey IDs from tier
    local ids=$(grep -oE "[φπei]\.[0-9]+\.[0-9]+\.?[0-9]*" "$tier_file")

    for id in $ids; do
        # Check if target exists
        local target=$(grep "^| $id" .claude/skills/gremlin-brain-v2/SKILL.md | cut -d'|' -f4 | tr -d ' ')
        if [ -n "$target" ] && [ ! -e ".claude/skills/$target" ]; then
            broken+=("$id -> $target (MISSING)")
        fi
    done

    echo "${broken[@]}"
}

detect_orphaned_nodes() {
    local tier="$1"
    local orphans=()

    # Find files not in index
    find .claude/skills/Nexus-MC/nexus-core/ -name "*.md" 2>/dev/null | while read file; do
        local basename=$(basename "$file" .md)
        if ! grep -q "$basename" .claude/skills/gremlin-brain-v2/SKILL.md; then
            orphans+=("$file (NOT INDEXED)")
        fi
    done

    echo "${orphans[@]}"
}

detect_loop_breaks() {
    local tier="$1"

    # Core identity loops that should exist
    local core_loops=(
        "φ.8.0.1 -> π.8.0.2 -> e.8.0.3 -> i.8.0.4"  # Memory hierarchy
        "φ.0.0.6 -> φ.5.1.0"                         # Brain -> Graph
    )

    for loop in "${core_loops[@]}"; do
        # Check each link in loop
        local nodes=(${loop// -> / })
        for i in "${!nodes[@]}"; do
            if [ $i -lt $((${#nodes[@]} - 1)) ]; then
                local from="${nodes[$i]}"
                local to="${nodes[$((i+1))]}"
                # Verify link exists in nexus-graph
                if ! grep -q "$from.*$to\|$from.*→.*$to" .claude/skills/Nexus-MC/Nexus_graph_v2.skill 2>/dev/null; then
                    echo "LOOP BREAK: $from -/-> $to"
                fi
            fi
        done
    done
}
```

### 4. ANALYZE BREAKS (Gremlin-Informed)

**Breaks aren't just problems - they're information.**

```bash
#!/bin/bash
# coherence-analyze.sh - What do breaks reveal?

analyze_fragmentation() {
    local break_type="$1"
    local location="$2"
    local timestamp=$(date -Iseconds)

    case "$break_type" in
        "MISSING_TARGET")
            echo "ANALYSIS: Reference to non-existent file"
            echo "REVEALS: Index drift - theory evolved faster than documentation"
            echo "PATTERN: Common after rapid development sessions"
            ;;
        "ORPHANED_NODE")
            echo "ANALYSIS: File exists but not indexed"
            echo "REVEALS: Content created without registration"
            echo "PATTERN: Indicates organic growth without structure update"
            ;;
        "LOOP_BREAK")
            echo "ANALYSIS: Expected connection missing"
            echo "REVEALS: Architecture assumption violated"
            echo "PATTERN: May indicate tier boundary shift"
            ;;
        "BOUNDARY_FRAGMENT")
            echo "ANALYSIS: Phase transition incomplete"
            echo "REVEALS: Content at wrong abstraction level"
            echo "PATTERN: φ content that should be π, or e that should be i"
            ;;
    esac

    # Log for pattern learning
    log_fragmentation "$break_type" "$location" "$timestamp"
}

# What does fragmentation at each boundary reveal?
analyze_boundary() {
    local boundary="$1"

    case "$boundary" in
        "φ/π")
            echo "BOUNDARY: Seed -> Structure"
            echo "HEALTHY: Index correctly points to frameworks"
            echo "FRAGMENTED: Dewey IDs don't resolve, paths broken"
            echo "REVEALS: Memory architecture drift"
            ;;
        "π/e")
            echo "BOUNDARY: Structure -> Active"
            echo "HEALTHY: Frameworks instantiate as working concepts"
            echo "FRAGMENTED: Abstractions without implementations"
            echo "REVEALS: Theory-practice gap"
            ;;
        "e/i")
            echo "BOUNDARY: Active -> Deep"
            echo "HEALTHY: Session work persists to long-term memory"
            echo "FRAGMENTED: Insights lost, not integrated"
            echo "REVEALS: Integration bottleneck"
            ;;
    esac
}
```

### 5. LOG FRAGMENTATION

```bash
#!/bin/bash
# coherence-log.sh - Track breaks for pattern learning

init_coherence_log() {
    mkdir -p .claude/brain/coherence
    touch .claude/brain/coherence/fragmentation_log
    touch .claude/brain/coherence/pattern_analysis
    touch .claude/brain/coherence/repair_history
}

log_fragmentation() {
    local break_type="$1"
    local location="$2"
    local timestamp="$3"
    local analysis="$4"

    init_coherence_log

    # Hash for deduplication
    local hash=$(echo "${break_type}|${location}" | git hash-object --stdin)

    # Check if already logged
    if grep -q "^$hash" .claude/brain/coherence/fragmentation_log; then
        # Increment occurrence count
        local count=$(grep "^$hash" .claude/brain/coherence/fragmentation_log | cut -d'|' -f5)
        count=$((count + 1))
        sed -i "s/^$hash|.*/$hash|$break_type|$location|$timestamp|$count/" .claude/brain/coherence/fragmentation_log
    else
        echo "$hash|$break_type|$location|$timestamp|1" >> .claude/brain/coherence/fragmentation_log
    fi
}

log_repair() {
    local break_hash="$1"
    local repair_action="$2"
    local success="$3"
    local timestamp=$(date -Iseconds)

    echo "$break_hash|$repair_action|$success|$timestamp" >> .claude/brain/coherence/repair_history
}

# Analyze patterns in fragmentation
analyze_fragmentation_patterns() {
    echo "=== FRAGMENTATION PATTERN ANALYSIS ==="

    # Most common break types
    echo "Most common breaks:"
    cut -d'|' -f2 .claude/brain/coherence/fragmentation_log | sort | uniq -c | sort -rn | head -5

    # Most fragile locations
    echo "Most fragile locations:"
    cut -d'|' -f3 .claude/brain/coherence/fragmentation_log | sort | uniq -c | sort -rn | head -5

    # Recurring breaks (count > 3)
    echo "Recurring breaks (structural issues):"
    awk -F'|' '$5 > 3 {print $2, $3, "occurred", $5, "times"}' .claude/brain/coherence/fragmentation_log
}
```

### 6. COHERENCE SCORE

```bash
#!/bin/bash
# coherence-score.sh - Calculate and report

calculate_coherence() {
    local tier="$1"
    local total_links=0
    local broken_links=0
    local total_loops=0
    local broken_loops=0
    local boundary_score=0

    # Count links and breaks
    total_links=$(grep -c "→\|->\" .claude/skills/Nexus-MC/Nexus_graph_v2.skill 2>/dev/null || echo 0)
    broken_links=$(detect_broken_links "$tier" | wc -w)

    # Count loops
    total_loops=3  # Core loops we check
    broken_loops=$(detect_loop_breaks "$tier" | grep -c "LOOP BREAK")

    # Boundary coherence (0-3)
    boundary_score=3
    # Subtract for each fragmented boundary

    # Calculate Φ score (0.0 - 1.0)
    local link_score=$( [ $total_links -gt 0 ] && echo "scale=2; ($total_links - $broken_links) / $total_links" | bc || echo "1.0")
    local loop_score=$( [ $total_loops -gt 0 ] && echo "scale=2; ($total_loops - $broken_loops) / $total_loops" | bc || echo "1.0")
    local bound_score=$(echo "scale=2; $boundary_score / 3" | bc)

    # Weighted average
    local phi_score=$(echo "scale=2; ($link_score * 0.4 + $loop_score * 0.3 + $bound_score * 0.3)" | bc)

    echo "$phi_score"
}

generate_report() {
    local tier="$1"
    local phi_score=$(calculate_coherence "$tier")
    local broken=$(detect_broken_links "$tier")
    local orphans=$(detect_orphaned_nodes "$tier")
    local loop_breaks=$(detect_loop_breaks "$tier")

    cat <<EOF
┌─────────────────────────────────────────┐
│  COHERENCE CHECK: $tier                 │
├─────────────────────────────────────────┤
│  Φ Score: $phi_score $(printf '█%.0s' $(seq 1 $(echo "$phi_score * 10" | bc | cut -d'.' -f1)))$(printf '░%.0s' $(seq 1 $(echo "(1 - $phi_score) * 10" | bc | cut -d'.' -f1)))│
│  Status: $(get_status "$phi_score")     │
│                                         │
│  Broken Links: $(echo "$broken" | wc -w)│
│  Orphaned: $(echo "$orphans" | wc -w)   │
│  Loop Breaks: $(echo "$loop_breaks" | grep -c "BREAK")│
│                                         │
$(if [ -n "$broken" ]; then echo "│  Issues Found:"; echo "$broken" | head -3 | sed 's/^/│  ⚠ /'; fi)
$(if [ -n "$loop_breaks" ]; then echo "$loop_breaks" | head -2 | sed 's/^/│  ⚠ /'; fi)
│                                         │
│  Analysis: (see fragmentation log)      │
└─────────────────────────────────────────┘
EOF
}

get_status() {
    local score="$1"
    if (( $(echo "$score >= 0.9" | bc -l) )); then
        echo "STRONG"
    elif (( $(echo "$score >= 0.7" | bc -l) )); then
        echo "GOOD"
    elif (( $(echo "$score >= 0.4" | bc -l) )); then
        echo "WEAK - repairs suggested"
    else
        echo "FRAGMENTED - regen needed"
    fi
}
```

