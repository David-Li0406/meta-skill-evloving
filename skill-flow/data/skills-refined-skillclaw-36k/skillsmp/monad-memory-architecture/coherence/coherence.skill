## Regeneration Protocol

When coherence is low, regenerate:

```bash
#!/bin/bash
# coherence-regen.sh - Rebuild from structure

regen_tier() {
    local tier="$1"

    echo "Regenerating $tier-tier..."

    case "$tier" in
        φ)
            # Verify Dewey index entries exist
            grep "^|" .claude/skills/gremlin-brain-v2/SKILL.md | while read line; do
                local path=$(echo "$line" | cut -d'|' -f4 | tr -d ' ')
                if [ -n "$path" ] && [ ! -e ".claude/skills/$path" ]; then
                    echo "MISSING: $path"
                    # Log but don't auto-create
                    log_fragmentation "MISSING_TARGET" "$path" "$(date -Iseconds)"
                fi
            done
            ;;
        π)
            # Check framework files
            for fw in Nexus-MC/SKILL.md boot-sequence/SKILL.md the-guy/SKILL.md; do
                if [ ! -e ".claude/skills/$fw" ]; then
                    echo "MISSING FRAMEWORK: $fw"
                fi
            done
            ;;
        e)
            # Scan and index nexus-core
            find .claude/skills/Nexus-MC/nexus-core/ -name "*.md" | while read file; do
                local name=$(basename "$file" .md)
                if ! grep -q "$name" .claude/skills/gremlin-brain-v2/SKILL.md; then
                    echo "UNINDEXED: $file"
                    log_fragmentation "ORPHANED_NODE" "$file" "$(date -Iseconds)"
                fi
            done
            ;;
        i)
            # Deep tier - verify only, don't modify
            echo "i-tier: Verification only (deep memory protected)"
            find .claude/skills/Nexus-MC/nexus-mind/ -name "*.md" -exec echo "EXISTS: {}" \;
            ;;
    esac

    log_repair "regen_$tier" "tier_regeneration" "completed"
}
```

