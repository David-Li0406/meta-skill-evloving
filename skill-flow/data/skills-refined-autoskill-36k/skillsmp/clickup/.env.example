# ClickUp API Configuration
# Get your personal API token from: ClickUp Settings → Apps → API Token

# Required: Your personal API token (starts with pk_)
CLICKUP_API_TOKEN=pk_your_token_here

# Required: Your workspace ID (found in ClickUp URL: app.clickup.com/WORKSPACE_ID/home)
CLICKUP_WORKSPACE_ID=your_workspace_id

# Optional: Your user ID (for filtering "my" tasks)
# Find via: npx clickup members list
CLICKUP_USER_ID=

# Optional: Default team/workspace for time entries
CLICKUP_TEAM_ID=
