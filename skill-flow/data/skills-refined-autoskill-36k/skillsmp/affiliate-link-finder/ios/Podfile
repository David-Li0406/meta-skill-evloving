# 1. Set the global platform to iOS 26
platform :ios, '26.0'

install! 'cocoapods', :disable_input_output_paths => true
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "Run flutter pub get first."
  end
  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

target 'Runner' do
  use_frameworks!
  use_modular_headers!
  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
  target 'RunnerTests' do
    inherit! :search_paths
  end
end

platform :ios, '26.0'

# ... (keep your def flutter_root and target 'Runner' blocks as they are)

post_install do |installer|
  installer.generated_projects.each do |project|
    project.targets.each do |target|
      target.build_configurations.each do |config|
        # 1. Force everything to iOS 26.0
        config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '26.0'
        
        # 2. THE KILLER FIX for the -G error
        # Strips out the legacy flag that Xcode 16/26 misreads
        config.build_settings['GCC_WARN_INHIBIT_ALL_WARNINGS'] = 'NO'
        if config.build_settings['OTHER_CFLAGS']
          config.build_settings['OTHER_CFLAGS'] = config.build_settings['OTHER_CFLAGS'].gsub('-GCC_WARN_INHIBIT_ALL_WARNINGS', '')
        end
        
        # 3. Security & Modernization
        config.build_settings['ENABLE_BITCODE'] = 'NO'
        config.build_settings['SWIFT_VERSION'] = '5.0'
      end
    end
  end
end



