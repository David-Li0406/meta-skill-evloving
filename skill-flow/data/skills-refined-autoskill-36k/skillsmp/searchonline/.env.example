# Search Online API Keys
# Copy this file to .env and fill in your API keys

# Required: Google Gemini API key for AI summarization
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: Tavily API key for advanced search
TAVILY_API_KEY=your_tavily_api_key_here

# Optional: WebSearchAPI key for additional search results
WEBSEARCHAPI_KEY=your_websearchapi_key_here
