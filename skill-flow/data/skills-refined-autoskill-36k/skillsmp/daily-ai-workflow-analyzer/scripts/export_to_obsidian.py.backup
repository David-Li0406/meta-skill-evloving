#!/usr/bin/env python3
"""
导出分析结果到Obsidian笔记
"""

import json
import os
from datetime import datetime
from pathlib import Path


class ObsidianExporter:
    """Obsidian笔记导出器"""

    def __init__(self, obsidian_vault_path):
        self.vault_path = Path(obsidian_vault_path)
        self.knowledge_base_path = self.vault_path / "知识体系" / "个人工作模式"

        self.knowledge_base_path.mkdir(parents=True, exist_ok=True)

        self.app_type_map = {
            "聊天": ["微信", "WeChat", "QQ", "钉钉", "飞书", "WhatsApp", "Telegram"],
            "编程": [
                "Antigravity",
                "Alma",
                "Dia",
                "Ghostty",
                "CodeBuddy CN",
                "Conductor",
                "CodeBuddy",
            ],
            "文档": ["Google Chrome", "Safari", "Finder"],
        }

    def export_analysis(self, analysis_data):
        """导出分析结果为Obsidian笔记"""
        app_name = analysis_data["app_name"]
        date = analysis_data["date"]

        note_content = self._generate_note_content(analysis_data)
        app_type = self._get_app_type(app_name)
        suffix = self._get_app_suffix(app_type)

        note_filename = f"{app_name}{suffix}_{date}.md"
        note_path = self.knowledge_base_path / note_filename

        with open(note_path, "w", encoding="utf-8") as f:
            f.write(note_content)

        print(f"✓ 已保存到: {note_path}")

        self._update_knowledge_base(analysis_data)

        return str(note_path)

    def _get_app_type(self, app_name):
        for app_type, apps in self.app_type_map.items():
            if app_name in apps:
                return app_type
        return "通用"

    def _get_app_suffix(self, app_type):
        suffix_map = {
            "聊天": "聊天记录",
            "编程": "开发记录",
            "文档": "使用记录",
            "通用": "记录",
        }
        return suffix_map.get(app_type, "记录")

    def _generate_note_content(self, data):
        app = data["app_name"]
        date = data["date"]
        total = data["total_records"]
        app_type = self._get_app_type(app)
        suffix = self._get_app_suffix(app_type)

        content = f"""# {app} {suffix} - {date}

> 💡 从{total}条语音记录中提取的可沉淀知识

---

## 🔄 重复出现的问题（需要沉淀为规则）

"""

        # 重复问题
        repeated = data.get("repeated_issues", [])
        if repeated:
            for issue in repeated:
                content += f"""### {issue["category"]} (出现{issue["count"]}次)

**模式**：{issue["pattern"]}

**示例**：
"""
                for example in issue["examples"]:
                    content += f"- {example}\n"

                content += f"""
**应该沉淀为**：✅ {issue["should_become_rule"]}

---

"""
        else:
            content += "暂无重复问题发现。\n\n"

        content += "## 🧠 用户习惯和偏好\n\n"
        habits = data.get("user_habits", [])
        if habits:
            for habit in habits:
                content += f"""### {habit["category"]} (出现{habit["count"]}次)

 **习惯描述**：{habit["habit"]}

 **示例**：
 """
                for example in habit["examples"]:
                    content += f"- {example}\n"

                content += "\n---\n\n"
        else:
            content += "暂无用户习惯发现。\n\n"

        content += "## ✅ 可执行的行动清单\n\n"
        actions = data.get("actionable_items", [])
        if actions:
            for action in actions:
                content += f"""### {action["category"]}

 **建议类型**：{action["description"]}

 **示例**：
 - {action["example"][:100]}...

---

"""
        else:
            content += "暂无行动清单发现。\n\n"

        content += "## 💬 沟通模式\n\n"
        comm = data.get("communication_patterns", [])
        if comm:
            for pattern in comm:
                content += f"""### {pattern["category"]} (出现{pattern["count"]}次)

 **模式描述**：{pattern["description"]}

 **示例**：
 """
                for example in pattern["examples"]:
                    content += f"- {example}\n"

                content += "\n---\n\n"
        else:
            content += "暂无沟通模式发现。\n\n"

        content += "## 🧠 知识洞察\n\n"
        insights = data.get("knowledge_insights", [])
        if insights:
            for insight in insights:
                content += f"""### {insight["category"]} (出现{insight["count"]}次)

 **洞察类型**：{insight["description"]}

 **示例**：
 """
                for example in insight["examples"]:
                    content += f"- {example}\n"

                content += "\n---\n\n"
        else:
            content += "暂无知识洞察发现。\n\n"

        workflow = data.get("workflow_preferences", [])
        if workflow:
            content += "## ⚙️ 工作流偏好\n\n"
            for pref in workflow:
                content += f"""### {pref["category"]} (出现{pref["count"]}次)

 **建议配置**：{pref["config"]}

 **示例**：
 """
                for example in pref["examples"]:
                    content += f"- {example}\n"

                content += "\n---\n\n"

        content += f"""## 🔗 相关链接

 - [[用户习惯清单]] - 你的工作习惯和偏好
 - [[工作模式配置]] - 自动化和流程配置
 - [[偏好设置]] - 个人化设置和期望

 ---

 tags: #AI协作 #{suffix} #{app}
 created: {date}
 """

        return content

    def export_comprehensive(self, data):
        """导出跨App综合分析报告"""
        date = datetime.now().strftime("%Y-%m-%d")
        total_records = data["total_records"]
        total_apps = data["total_apps"]
        cross_issues = data["summary"]["cross_app_issues"]
        top_patterns = data["summary"]["top_patterns"]

        content = f"""# 综合深度洞察分析报告 - {date}

> 💡 从{total_records}条语音记录（{total_apps}个应用）中提取的可沉淀知识

---

## ⚡ 执行摘要

**核心发现**：跨App分析揭示了{len(cross_issues)}类重复出现的问题，需要立即解决。

**重复问题TOP3**：
"""
        # TOP3跨App重复问题
        for i, (category, count) in enumerate(cross_issues[:3], 1):
            emoji = "🔴" if i == 1 else "🟡" if i == 2 else "🟢"
            content += f"\n{i}. {emoji} **{category}**（{count}次）\n"

        content += "\n**关键洞察**：\n"

        # 合并所有App的新原则
        all_principles = []
        for app_analysis in data.get("app_analyses", []):
            all_principles.extend(app_analysis.get("new_principles", []))

        if all_principles:
            content += f"- 你已经表达了**{len(all_principles)}次**自动化期望，但这些都未转化为可执行的配置\n"
            content += "- 这说明：**'表达偏好' ≠ '固化偏好'**\n
        content += """
---

## 🔄 需要立即解决的问题（跨App）

"""
        # 跨App重复问题
        if cross_issues:
            for category, total_count in cross_issues[:5]:
                content += f"\n### {category}（共{total_count}次）\n\n"
                content += "**涉及应用**："
                apps_with_issue = []
                for app_analysis in data.get("app_analyses", []):
                    for issue in app_analysis.get("repeated_issues", []):
                        if issue["category"] == category:
                            apps_with_issue.append(app_analysis["app_name"])
                            content += f"\n**典型表现**：\n"
                            for example in issue["examples"][:2]:
                                content += f"- {example}\n"
                            content += f"\n**应该沉淀为**：✅ {issue['should_become_rule']}\n"
                            break

        content += "\n---

## 🎯 可执行的行动清单

### 立即执行

1. **建立强制性提交前自检清单**
   - 基础可用性验证
   - 核心功能测试
   - 交互一致性检查
   - 国际化验证

2. **固化中文沟通偏好为可执行配置**
   ```yaml
   communication:
     language: zh-CN
     tone: concise
   ```

3. **提取自动化期望，转化为可执行的偏好文件**

### 本周完成

4. **建立功能优先级矩阵** - 区分P0、P1、P2
5. **将重复问题转化为可执行的规则配置**

---

## 📊 数据快照

| 应用 | 记录数 | 主要问题 |
|------|--------|---------|
"""
        # 各应用统计
        for app_analysis in data.get("app_analyses", [])[:8]:
            app_name = app_analysis["app_name"]
            total = app_analysis["total_records"]
            issues = app_analysis.get("repeated_issues", [])
            if issues:
                main_issue = f"{issues[0]['category']}({issues[0]['count']}次)"
            else:
                main_issue = "-"
            content += f"| {app_name} | {total} | {main_issue} |\n"

        content += f"""
---

## 💎 可沉淀的核心原则

### 原则1：分层验证原则

**来源**：质量验证缺口问题（跨{total_apps}个应用）

**核心原则**：
> 开发过程中的验证应该分为3层，每一层都必须完成才能进入下一层：
> 1. **即时验证**：写完立即测
> 2. **功能验证**：提交前测
> 3. **系统验证**：上线前测

**适用范围**：所有代码/功能开发

---

### 原则2：价值优先原则

**来源**：局部优化陷阱

**核心原则**：
> 在MVP阶段，用80/20法则强制分配精力：
> - 80%：核心功能、用户体验痛点、性能优化
> - 20%：UI细节、边界优化、锦上添花

---

### 原则3：偏好固化原则

**来源**：{len(all_principles)}次自动化期望未落地

**核心原则**：
> 表达偏好 ≠ 固化偏好
> - 表达偏好：只是说出来，可能被遗忘
> - 固化偏好：转化为配置，自动执行

**适用范围**：所有AI交互配置

---

## 📝 附录

### 分析时间
- 生成时间：{datetime.now().strftime("%Y-%m-%d %H:%M:%S")}
- 数据范围：最近3天
- 分析工具：DailyAIWorkflowAnalyzer v2.1（综合版）

### 报告变更说明
- **v2.1**：不再生成单独的App开发记录，只生成综合分析报告
- **v2.0**：深度洞察版，识别行为模式和认知偏见
- **v1.0**：基础版，数据汇总

### 相关链接
- [[用户习惯清单]] - 你的工作习惯和偏好
- [[工作模式配置]] - 自动化和流程配置
- [[偏好设置]] - 个人化设置和期望

---

tags: #AI协作 #深度洞察 #综合分析
created: {date}
"""
        note_filename = f"综合分析报告_{date}.md"
        note_path = self.knowledge_base_path / note_filename

        with open(note_path, "w", encoding="utf-8") as f:
            f.write(content)

        print(f"✓ 已保存综合报告到: {note_path}")

        return str(note_path)

    def _update_knowledge_base(self, data):
        self._update_checklist(
            "用户习惯清单.md", data.get("repeated_issues", []), "用户习惯模式"
        )

        self._update_checklist(
            "工作模式配置.md", data.get("workflow_preferences", []), "工作流配置"
        )

        self._update_checklist(
            "偏好设置.md", data.get("code_quality_patterns", []), "偏好和设置"
        )

    def _update_checklist(self, filename, new_items, section_title):
        file_path = self.knowledge_base_path / filename
        now = datetime.now()

        weekdays = ["周一", "周二", "周三", "周四", "周五", "周六", "周日"]
        date_str = now.strftime("%Y-%m-%d")
        time_str = now.strftime("%H:%M:%S")
        weekday = weekdays[now.weekday()]
        full_datetime = f"{date_str} , {weekday} , {time_str}"

        if not file_path.exists():
            content = f"""---
 tags: []
 creation date: {full_datetime}
 modification date: {full_datetime}
 ---

 ## 自动积累的规则

 """
            with open(file_path, "w", encoding="utf-8") as f:
                f.write(content)
        else:
            with open(file_path, "r", encoding="utf-8") as f:
                content = f.read()

            import re

            content = re.sub(
                r"modification date: .*", f"modification date: {full_datetime}", content
            )

            with open(file_path, "w", encoding="utf-8") as f:
                f.write(content)

        if new_items:
            with open(file_path, "a", encoding="utf-8") as f:
                f.write(f"\n### 更新于 {date_str}\n\n")
                for item in new_items:
                    if isinstance(item, dict):
                        # 统一格式：- [ ] 类别: 内容
                        if "should_become_rule" in item:
                            category = item["category"]
                            rule = item["should_become_rule"]
                            f.write(f"- [ ] {category}: {rule}\n")
                        elif "prevention" in item:
                            category = item["type"]
                            prevention = item["prevention"]
                            f.write(f"- [ ] {category}: {prevention}\n")
                        elif "config" in item:
                            category = item["category"]
                            config = item["config"]
                            f.write(f"- [ ] {category}: {config}\n")

                f.write("\n")


def export_comprehensive_analysis(comprehensive_data, obsidian_path):
    """导出综合分析报告（跨App合并）"""
    exporter = ObsidianExporter(obsidian_path)
    note_path = exporter.export_comprehensive(comprehensive_data)
    return note_path


def export_analysis_to_obsidian(analysis_data, obsidian_path):
    """导出分析结果到Obsidian"""
    exporter = ObsidianExporter(obsidian_path)
    note_path = exporter.export_analysis(analysis_data)
    return note_path


if __name__ == "__main__":
    import sys

    if len(sys.argv) < 3:
        print(
            "Usage: python export_to_obsidian.py <analysis_json_file> <obsidian_vault_path>"
        )
        sys.exit(1)

    analysis_file = sys.argv[1]
    obsidian_path = sys.argv[2]

    # 读取分析结果
    with open(analysis_file, "r", encoding="utf-8") as f:
        analysis_data = json.load(f)

    # 导出
    note_path = export_analysis_to_obsidian(analysis_data, obsidian_path)
    print(f"成功导出到: {note_path}")
