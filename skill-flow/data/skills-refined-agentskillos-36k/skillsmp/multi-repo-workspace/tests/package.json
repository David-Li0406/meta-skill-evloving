{
  "name": "multi-repo-workspace-tests",
  "version": "1.0.0",
  "description": "Tests for Multi-Repo Workspace skill",
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "keywords": ["claude", "workspace", "multi-repo", "tests"],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "jest": "^29.7.0"
  },
  "jest": {
    "testEnvironment": "node",
    "coverageDirectory": "coverage",
    "collectCoverageFrom": [
      "../scripts/**/*.js",
      "!../scripts/node_modules/**"
    ]
  }
}
