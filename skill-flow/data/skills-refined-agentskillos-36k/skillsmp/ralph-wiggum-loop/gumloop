#!/bin/bash
# gumloop - The Ralph Wiggum Loop CLI
# 
# Run AI coding agents in autonomous loops until task completion.
# Based on Geoffrey Huntley's Ralph Wiggum methodology.
#
# Usage:
#   gumloop [options] [max_iterations]
#
# Options:
#   --cli AGENT         Coding agent to use (claude, codex, gemini, opencode, amp, aider)
#   --choo-choo         Enable autonomous mode (skip permission prompts)
#   --no-push           Don't push to remote after each iteration
#   -p, --prompt TEXT   Inline prompt text
#   --prompt-file FILE  Use prompt file (default: PROMPT.md)
#   --update            Update to latest version
#   --uninstall         Remove gumloop from system
#   --version           Show version
#   --help              Show this help
#
# Examples:
#   gumloop                                # Interactive mode
#   gumloop --choo-choo                    # Autonomous mode
#   gumloop --choo-choo 20                 # Autonomous, max 20 iterations
#   gumloop -p "Fix the tests"             # Inline prompt
#   gumloop --prompt-file PROMPT_plan.md   # Custom prompt file
#
# Environment:
#   GUMLOOP_CLI       Agent CLI to use (default: claude)
#   GUMLOOP_FLAGS     Custom flags for unsupported CLIs
#
# More info: https://github.com/ghuntley/ralph-wiggum-loop

set -euo pipefail

# Handle Ctrl+C gracefully
trap 'echo ""; echo ""; echo "🛑 Interrupted. Exiting gumloop."; exit 130' INT

VERSION="1.0.0"

# ============================================================================
# CONFIGURATION
# ============================================================================

CLI="${GUMLOOP_CLI:-claude}"
YOLO_MODE=false
AUTO_PUSH=true
PROMPT_TEXT=""
PROMPT_FILE="PROMPT.md"
MAX_ITERATIONS=0
STUCK_THRESHOLD=3
VERIFY_CMD=""

# Check for jq availability (for better JSON parsing)
HAS_JQ=false
if command -v jq &> /dev/null; then
    HAS_JQ=true
fi

