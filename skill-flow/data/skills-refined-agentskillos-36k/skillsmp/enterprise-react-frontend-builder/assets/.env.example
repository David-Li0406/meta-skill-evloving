# Environment Variables Template
# Copy this file to .env and fill in your values

# API Configuration
VITE_API_BASE_URL=http://localhost:3000/api

# Application
VITE_APP_NAME=My App
VITE_APP_VERSION=1.0.0

# OAuth 2.0 Configuration (if using OAuth)
VITE_OAUTH_CLIENT_ID=your-client-id
VITE_OAUTH_AUTHORIZE_URL=https://auth.example.com/oauth2/authorize
VITE_OAUTH_TOKEN_URL=https://auth.example.com/oauth2/token
VITE_OAUTH_REDIRECT_URI=http://localhost:5173/auth/callback

# Azure AD Configuration (example)
# VITE_AZURE_CLIENT_ID=your-azure-client-id
# VITE_AZURE_TENANT_ID=your-tenant-id

# Auth0 Configuration (example)
# VITE_AUTH0_DOMAIN=your-domain.auth0.com
# VITE_AUTH0_CLIENT_ID=your-auth0-client-id

# Feature Flags
VITE_ENABLE_MOCKS=false
VITE_ENABLE_DEVTOOLS=true

# Analytics (optional)
# VITE_GA_TRACKING_ID=G-XXXXXXXXXX

# Error Tracking (optional)
# VITE_SENTRY_DSN=https://xxx@sentry.io/xxx