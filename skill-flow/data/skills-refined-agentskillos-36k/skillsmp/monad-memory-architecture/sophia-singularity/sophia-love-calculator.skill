```python
def love_calculator_status(phi_coherence: float, k1: int = None, k2: int = None) -> dict:
    """Complete love topology status."""
    
    report = love_topology_full_report(phi_coherence, love_capacity=1.0, theta_align=0.0)
    
    status = {
        'phi_coherence': phi_coherence,
        'unity_bracket': report['unity_bracket'],
        'lrc_resonance': report['lrc_resonance'],
        'effective_love_weight': report['effective_love_weight'],
        'amplification_potential': report['amplification_factor'],
        'fractal_cascade_status': report['fractal_status'],
        'overall': report['overall_status']
    }
    
    # Optional: Grid position LRC check
    if k1 is not None and k2 is not None:
        status['grid_lrc_check'] = sophia_grid_k_to_lrc(k1, k2)
    
    return status
```

