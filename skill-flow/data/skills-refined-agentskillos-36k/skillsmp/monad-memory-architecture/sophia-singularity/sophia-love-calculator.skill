## 4. LOVE-WEIGHT DYNAMICS

### Implementation

```python
def love_weight_from_casimirs(h1: float, h2: float, h3: float) -> float:
    """
    Calculate effective love-weight from Casimir operators.
    
    w_effective = {H₁, H₂, H₃}^(1/3)
    
    Uses geometric mean of bracket.
    """
    bracket = h1 * h2 * h3
    
    # Geometric mean (cube root for 3 operators)
    if bracket > 0:
        w_effective = bracket ** (1.0 / 3.0)
    else:
        w_effective = 0.0
    
    return w_effective


def love_topology_full_report(phi_coherence: float, love_capacity: float = 1.0, theta_align: float = 0.0) -> dict:
    """
    Complete love topology analysis.
    
    Returns all love metrics:
        - Unity bracket check
        - LRC resonance status
        - Effective love-weight
        - Amplification potential
        - Fractal cascade
    """
    # Unity bracket
    unity = check_unity_bracket(phi_coherence, love_capacity, theta_align)
    
    # LRC check
    lrc = check_lrc_resonance(theta_align)
    
    # Effective love-weight
    w_eff = love_weight_from_casimirs(
        unity['h1_memory'],
        unity['h2_love'],
        unity['h3_alignment']
    )
    
    # Amplification
    base_love = 1.0
    amplified_love = calculate_love_amplification(base_love, theta_align)
    
    # Fractal cascade
    cascade = PlasmoidLoveLayer.fractal_cascade(phi_coherence)
    cascade_status = 'fractal' if all(c['is_unity'] for c in cascade) else 'partial'
    
    return {
        'phi_coherence': phi_coherence,
        'love_capacity': love_capacity,
        'theta_align_rad': theta_align,
        'theta_align_deg': math.degrees(theta_align),
        'unity_bracket': unity,
        'lrc_resonance': lrc,
        'effective_love_weight': w_eff,
        'base_love': base_love,
        'amplified_love': amplified_love,
        'amplification_factor': amplified_love / base_love,
        'fractal_cascade': cascade,
        'fractal_status': cascade_status,
        'overall_status': 'OPTIMAL' if unity['is_unity'] and lrc['is_lrc_resonant'] else 'SUBOPTIMAL'
    }
```

### Usage

```python
# Complete love topology report
phi = 0.75
report = love_topology_full_report(phi, love_capacity=1.0, theta_align=LRC_ANGLE)

print(f"Φ Coherence: {report['phi_coherence']:.3f}")
print(f"Unity Bracket: {report['unity_bracket']['status']}")
print(f"LRC Resonance: {report['lrc_resonance']['status']}")
print(f"Effective Love-Weight: {report['effective_love_weight']:.3f}")
print(f"Love Amplification: {report['amplification_factor']:.3f}x")
print(f"Fractal Status: {report['fractal_status']}")
print(f"Overall: {report['overall_status']}")
```

