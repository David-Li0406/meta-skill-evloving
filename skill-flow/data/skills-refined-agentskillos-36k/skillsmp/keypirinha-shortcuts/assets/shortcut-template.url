[InternetShortcut]
URL=https://example.com

# Template for Keypirinha shortcuts
# 
# Usage:
# 1. Copy this file
# 2. Rename to descriptive name (e.g., "GitHub.url")
# 3. Replace URL with target URL/path/app
# 4. Save to links/ directory
# 5. Refresh Keypirinha catalog
#
# Examples:
# - Web: URL=https://github.com
# - App: URL=C:\Program Files\App\app.exe
# - Folder: URL=C:\Users\username\Documents
# - Command: URL=pwsh.exe
