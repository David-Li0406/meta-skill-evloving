{
  "grammar_rules": [
    {
      "rule": "subject_verb_agreement",
      "description": "检查主谓一致性",
      "patterns": ["主语和谓语在数上不一致", "复数主语搭配单数谓语"]
    },
    {
      "rule": "tense_consistency",
      "description": "保持时态一致性",
      "patterns": ["时态混乱", "过去时和现在时混用"]
    },
    {
      "rule": "punctuation",
      "description": "优化标点符号使用",
      "patterns": ["逗号滥用", "缺少句号", "标点错误"]
    }
  ],
  "vocabulary_improvements": {
    "weak_verbs": [
      {
        "weak": "是",
        "strong": ["构成", "代表", "表明", "体现"],
        "context": "描述定义或性质时"
      },
      {
        "weak": "做",
        "strong": ["执行", "实施", "开展", "进行"],
        "context": "正式场合"
      },
      {
        "weak": "说",
        "strong": ["指出", "表示", "认为", "强调"],
        "context": "引用或观点表达"
      }
    ],
    "vague_words": [
      {
        "vague": "一些",
        "precise": ["若干", "部分", "一定"],
        "context": "需要更准确表达"
      },
      {
        "vague": "很多",
        "precise": ["众多", "大量", "相当数量"],
        "context": "正式场合"
      },
      {
        "vague": "好",
        "precise": ["良好", "优秀", "出色"],
        "context": "需要明确评价等级"
      }
    ]
  },
  "structure_rules": {
    "sentence_length": {
      "min": 5,
      "max": 50,
      "ideal_range": "15-30"
    },
    "paragraph_length": {
      "min": 2,
      "max": 10,
      "ideal": "4-6"
    },
    "transition_words": [
      "然而",
      "因此",
      "此外",
      "同时",
      "首先",
      "最后",
      "由此可见",
      "综上所述"
    ]
  },
  "tone_adjustments": {
    "formal": {
      "avoid": ["口语化表达", "网络用语", "非正式缩写"],
      "prefer": ["完整句式", "规范用词", "专业术语"]
    },
    "semi_formal": {
      "avoid": ["过度口语", "过度正式"],
      "prefer": ["自然流畅", "准确表达"]
    },
    "casual": {
      "avoid": ["过于正式", "生硬表达"],
      "prefer": ["口语化", "轻松自然"]
    }
  }
}
